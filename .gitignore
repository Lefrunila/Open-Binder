data/esm_ppi_*.csv
data/structures/
data/*.bak_*
data/*.log

# Exceptions: always include these specific files
!examples/9YC3_relaxed.pdb
!models/checkpoints/*/meta.json
!models/checkpoints/*/metrics.json
!models/checkpoints/esm_pca.joblib
!models/loo_results/*/pooled_metrics.json
!models/loo_results/*/pass_rate_by_antigen.csv

